#le multi-stage build réduit significativement la taille des images et l'empreinte d'attaque en séparant l'environnement de compilation de l'image runtime minimale; cela diminue également le temps de pull/push et évite d'exposer des outils inutiles en productions.

FROM node:18-alpine
WORKDIR /usr/src/app
COPY package*.json ./
RUN npm install --production
COPY . .
EXPOSE 3000
CMD ["node", "server.js"]# backend/Dockerfile

# ---------- Stage 1: builder ----------
FROM node:18 AS builder
WORKDIR /usr/src/app

# Copier uniquement les fichiers de dépendances pour profiter du cache
COPY package*.json ./

# Installer toutes les dépendances
RUN npm ci

# Copier le reste du code
COPY . .

# Exécuter les tests; la build échoue si les tests échouent
ARG SKIP_TESTS=0
RUN if [ "$SKIP_TESTS" = "0" ]; then npm test; else echo "Skipping tests"; fi

# ---------- Stage 2: production ----------
FROM node:18-alpine AS production
WORKDIR /usr/src/app


# Copier package.json et node_modules depuis le builder
COPY --from=builder /usr/src/app/package*.json ./
COPY --from=builder /usr/src/app/node_modules ./node_modules

# Copier le code applicatif
COPY --from=builder /usr/src/app ./

# Variables d'environnement pour la production
ENV NODE_ENV=production
ENV PORT=3000

EXPOSE 3000

# S'assurer que les fichiers appartiennent à l'utilisateur node et exécuter en non-root
RUN chown -R node:node /usr/src/app
USER node

CMD ["node", "server.js"]